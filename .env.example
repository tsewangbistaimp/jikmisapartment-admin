DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jikmis_apartment?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Password for the seeded Owner/Admin account (prisma/seed.js). Set this
# before seeding a real environment — without it, seeding falls back to the
# insecure dev-only default "admin12345" and prints a warning. Change the
# password after first login (PATCH /auth/password) regardless.
SEED_ADMIN_PASSWORD="replace-with-a-strong-password"
PORT=4000
HOST="127.0.0.1"
CLIENT_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Public base URL of the Next.js site itself — used server-side (the Express
# API, which has no window.location) to build the public invoice page link
# (/invoice/:token) embedded in "Send invoice to guest" emails. Falls back to
# CLIENT_URL if unset, so this only needs to be set explicitly if the two
# ever differ (e.g. a custom domain in production).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"

# Homepage hero "Check availability" form.
# Formspree form pointed at jikmisdonkhang@gmail.com. Already set as the code
# default too, so this only needs to change if you create a new Formspree form.
NEXT_PUBLIC_FORMSPREE_ENDPOINT="https://formspree.io/f/xvzepwkw"

# Guest communication automation (lib/mailer.js). Any standard SMTP relay
# works: Gmail (use an App Password, not your normal password), Resend,
# SendGrid, etc. If these are left unset, booking confirmation/reminder/
# thank-you emails are silently skipped (logged as a warning) — booking
# creation itself is never blocked by missing email config.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password-or-app-password"
SMTP_FROM="Jikmis Apartment <jikmisdonkhang@gmail.com>"

# Secret shared with Vercel Cron (see vercel.json) to authorize requests to
# /api/cron/send-reminders. Vercel sets this automatically as a Bearer token
# on scheduled invocations once CRON_SECRET is set in the project's env vars.
# If left unset, the endpoint runs unauthenticated — set this in production.
CRON_SECRET="replace-with-a-long-random-secret"
